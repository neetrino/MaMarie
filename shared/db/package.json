{
  "name": "@white-shop/db",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./env": {
      "types": "./env.ts",
      "default": "./env.ts"
    }
  },
  "scripts": {
    "db:generate": "node scripts/run-with-root-env.cjs generate",
    "db:push": "node scripts/run-with-root-env.cjs db push",
    "db:migrate": "node scripts/run-with-root-env.cjs migrate dev",
    "db:migrate:deploy": "node scripts/run-with-root-env.cjs migrate deploy",
    "db:studio": "node scripts/run-with-root-env.cjs studio",
    "db:seed": "node scripts/run-with-root-env.cjs db seed",
    "postinstall": "node scripts/run-with-root-env.cjs generate"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "prisma": "^5.9.0"
  }
}

